# ── Clerk (auth) ────────────────────────────────────────────
# Get from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=REPLACE_WITH_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=REPLACE_WITH_CLERK_SECRET_KEY

# Clerk redirect URLs (keep as-is for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding
# Comma-separated Clerk user IDs with admin access (creator/operator accounts)
APP_ADMIN_CLERK_USER_IDS=user_xxxxxxxxxxxxxxxx
# Set true in local/dev if you want every signed-in user to have admin access
APP_ADMIN_ALLOW_ALL=false

# ── Supabase (database) ──────────────────────────────────────
# Get from https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyxxxxxxxxxxxxxxxxxxxxxxxx

# ── Paddle (payments) ────────────────────────────────────────
# Get from https://vendors.paddle.com → Developer Tools
PADDLE_API_KEY=REPLACE_WITH_PADDLE_API_KEY
PADDLE_WEBHOOK_SECRET=REPLACE_WITH_PADDLE_WEBHOOK_SECRET

# Paddle price IDs — create recurring prices in your Paddle catalog
# Business plans
PADDLE_PRICE_BUSINESS_STARTER=pri_01kns0r0vbvs81235sra9pm85g  # $49/mo
PADDLE_PRICE_BUSINESS_PRO=pri_01kns0xxsw22gcffx3s4m64jxp      # $99/mo
PADDLE_PRICE_BUSINESS_SCALE=pri_01kns1rxr733vwj1d4jn9wacnd     # $149/mo
# VA plan
PADDLE_PRICE_VA_VERIFIED=pri_01kns1gk8npzjp42sv21p4d1g4      # $29/mo

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Temporary switch: set true to let businesses message VAs without active subscriptions.
# Set to false when you want to enforce billing gates again.
APP_PAUSE_PAYMENTS=true
