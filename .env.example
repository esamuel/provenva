# ── Clerk (auth) ────────────────────────────────────────────
# Get from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=REPLACE_WITH_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=REPLACE_WITH_CLERK_SECRET_KEY

# Clerk redirect URLs (keep as-is for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── Supabase (database) ──────────────────────────────────────
# Get from https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyxxxxxxxxxxxxxxxxxxxxxxxx

# ── Stripe (payments) ────────────────────────────────────────
# Get from https://dashboard.stripe.com → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=REPLACE_WITH_STRIPE_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=REPLACE_WITH_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_STRIPE_WEBHOOK_SECRET

# Stripe price IDs — create these in your Stripe dashboard
# Business plans
STRIPE_PRICE_BUSINESS_STARTER=price_xxxxxxxxxxxxxxxxxxxxxxxx   # $49/mo
STRIPE_PRICE_BUSINESS_PRO=price_xxxxxxxxxxxxxxxxxxxxxxxx       # $99/mo
STRIPE_PRICE_BUSINESS_SCALE=price_xxxxxxxxxxxxxxxxxxxxxxxx     # $149/mo
# VA plan
STRIPE_PRICE_VA_VERIFIED=price_xxxxxxxxxxxxxxxxxxxxxxxx        # $29/mo

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
